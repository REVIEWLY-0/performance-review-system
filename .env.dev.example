# Dev environment variables for docker-compose.dev.yml
# Copy this to .env.dev and fill in the same values from backend/.env + frontend/.env.local
#
# Usage: docker compose -f docker-compose.dev.yml --env-file .env.dev up --build

# Supabase (copy from backend/.env)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Email / Mailtrap (copy from backend/.env)
MAILTRAP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_PORT=587
MAILTRAP_USER=your_mailtrap_user
MAILTRAP_PASS=your_mailtrap_password
EMAIL_FROM=Reviewly Dev <noreply@reviewly.com>
UNSUBSCRIBE_SECRET=dev-secret-change-me

# Frontend public vars (copy from frontend/.env.local)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_APP_NAME=Reviewly Dev
