# Database
# Option A — Local Postgres via Docker (fast, recommended for dev):
#   1. Run: docker-compose up -d  (from repo root)
#   2. Run: npx prisma migrate deploy
DATABASE_URL="postgresql://reviewly:reviewly@localhost:5432/reviewly"

# Option B — Supabase (staging / production):
# DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-1-eu-west-1.pooler.supabase.com:5432/postgres"
# DATABASE_URL_POOLER="postgresql://postgres.<ref>:<password>@aws-1-eu-west-1.pooler.supabase.com:6543/postgres"

# Supabase Auth
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_JWT_SECRET="your-jwt-secret-from-supabase-dashboard"

# Email (Mailtrap via Nodemailer)
# Get credentials from: https://mailtrap.io → Inboxes → SMTP Settings
MAILTRAP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_PORT=587
MAILTRAP_USER=your_mailtrap_user
MAILTRAP_PASS=your_mailtrap_password
EMAIL_FROM="Reviewly <noreply@reviewly.com>"

# Server
PORT=4000
NODE_ENV="development"

# CORS (comma-separated origins for production)
CORS_ORIGIN="http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003"
