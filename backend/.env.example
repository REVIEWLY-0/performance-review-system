# Database
# Option A — Local Postgres via Docker (fast, recommended for dev):
#   1. Run: docker-compose up -d  (from repo root)
#   2. Run: npx prisma migrate deploy
DATABASE_URL="postgresql://reviewly:reviewly@localhost:5433/reviewly"

# Option B — Supabase (staging / production):
# DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-1-eu-west-1.pooler.supabase.com:5432/postgres"
# DATABASE_URL_POOLER="postgresql://postgres.<ref>:<password>@aws-1-eu-west-1.pooler.supabase.com:6543/postgres"

# Supabase Auth + Storage
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_JWT_SECRET="your-jwt-secret-from-supabase-dashboard"
# Service role key — used server-side for avatar uploads to Supabase Storage.
# Find it in: Supabase Dashboard → Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Email (Mailtrap via Nodemailer)
# Get credentials from: https://mailtrap.io → Inboxes → SMTP Settings
MAILTRAP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_PORT=587
MAILTRAP_USER=your_mailtrap_user
MAILTRAP_PASS=your_mailtrap_password
EMAIL_FROM="Reviewly <noreply@reviewly.com>"

# Server
PORT=4000
NODE_ENV="development"
BACKEND_URL="http://localhost:4000"
FRONTEND_URL="http://localhost:3000"

# CORS (comma-separated origins for production)
CORS_ORIGIN="http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003"

# Email unsubscribe — used to sign unsubscribe tokens (HMAC-SHA256)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
UNSUBSCRIBE_SECRET="change-me-to-a-random-secret-in-production"

# Sentry error monitoring (optional — leave blank to disable)
# Create a project at https://sentry.io and paste the DSN here.
# For source map uploads in CI also set SENTRY_ORG and SENTRY_PROJECT.
SENTRY_DSN=""
