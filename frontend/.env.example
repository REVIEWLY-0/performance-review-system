# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"

# Backend API
NEXT_PUBLIC_API_URL="http://localhost:4000/api"

# App Config
NEXT_PUBLIC_APP_NAME="Reviewly"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Sentry error monitoring (optional — leave blank to disable)
# Create a project at https://sentry.io → Next.js and paste the DSN here.
# For source map uploads in CI also set SENTRY_ORG and SENTRY_PROJECT.
NEXT_PUBLIC_SENTRY_DSN=""
